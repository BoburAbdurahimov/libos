# PostgreSQL connection (Neon/Vercel Postgres/local all work)
DATABASE_URL="postgresql://user:password@localhost:5432/libos"

# Long random string used to sign JWTs — generate with: openssl rand -hex 32
JWT_SECRET="change-me"

# Anthropic API key — powers garment tagging, outfit AI and captions.
# Leave empty to run in mock-AI mode (deterministic fake responses, no cost).
ANTHROPIC_API_KEY=""
CLAUDE_MODEL="claude-opus-4-8"

# Public URL of this backend, used to build shareable bundle links
PUBLIC_BASE_URL="http://localhost:3000"
